<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<VBox spacing="10" alignment="CENTER" 
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="TemperatureConverterController"
      prefHeight="200.0" prefWidth="350.0">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>
    
    <Label text="Chuyển đổi nhiệt độ (C → F)" 
           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    
    <TextField fx:id="celsiusField" promptText="Nhập độ C"/>
    
    <Button text="Chuyển đổi" onAction="#convertTemperature"/>
    
    <Label fx:id="resultLabel" text="Kết quả: -- °F"/>
    
</VBox>